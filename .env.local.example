# ⚠️  VARIABLES DE ENTORNO - INFORMACIÓN SENSIBLE
# Este archivo muestra DÓNDE y CÓMO configurar las credenciales
# NUNCA commits este archivo a Git - añádelo a .gitignore

# ==============================================================================
# 🔐 CAJA FUERTE (VAULT) - ENCRIPTACIÓN
# ==============================================================================

# Clave de encriptación AES-256 (genérala con: GET /api/vault/generar-clave)
# Esta clave es ÚNICA para tu caja fuerte
# NUNCA la compartas ni la expongas
VAULT_CIPHER_KEY=tu_clave_encriptacion_aqui_generada_con_endpoint

# Clave secreta para generar tokens JWT
# Usa un valor aleatorio y único
VAULT_SECRET_KEY=tu_clave_secreta_super_segura_aqui_123

# ==============================================================================
# 🔐 STRIPE - CONFIGURACIÓN DE PAGOS SEGURA
# ==============================================================================

# Obtén estas claves en: https://dashboard.stripe.com/apikeys
# Clave Pública (PUBLISHABLE KEY) - Segura para enviar al cliente
STRIPE_PUBLISHABLE_KEY=pk_test_tu_clave_publica_aqui

# Clave Privada (SECRET KEY) - NUNCA la expongas en público
STRIPE_SECRET_KEY=sk_test_tu_clave_privada_aqui

